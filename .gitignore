# -------------------------------------------------------
# Dot-directories: ignore all, allowlist what we track
# -------------------------------------------------------
.*/
!.claude/
!.codex/rules/kubectl.rules
!.github/
!.renovate/
!.taskfiles

# -------------------------------------------------------
# OS
# -------------------------------------------------------
.DS_Store
Thumbs.db

# -------------------------------------------------------
# Editors
# -------------------------------------------------------
.vscode/
.monokle
*.profraw

# -------------------------------------------------------
# Secrets & environment
# -------------------------------------------------------
kubeconfig
*.*key
*.pem
*.pgp
*.pub
.config.env
*credentials*
.decrypted~*
.env
.envrc
cloudflare-tunnel.json

# -------------------------------------------------------
# Ansible
# -------------------------------------------------------
.venv*
ansible/.facts_cache/
ansible/galaxy
ansible/tmp

# -------------------------------------------------------
# Terraform
# -------------------------------------------------------
.terraform/
*.tfstate*
*.lock.hcl
*.ova
govcvars.sh
modules/terraform-vsphere/

# -------------------------------------------------------
# direnv
# -------------------------------------------------------
.direnv/*

# -------------------------------------------------------
# AI tooling (local/personal files only)
# -------------------------------------------------------
CLAUDE.md
CLAUDE.local.md
.claude/settings.local.json
settings.local.json
docs/superpowers/

# -------------------------------------------------------
# Python
# -------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.coverage
.coverage.*

# -------------------------------------------------------
# Dependencies & build output
# -------------------------------------------------------
node_modules/
build/
dist/
site/
**/cache/

# -------------------------------------------------------
# Temp, logs, & working files
# -------------------------------------------------------
*.bak
*.iso
*.log
*.zip
**/*archive/
**/*wip/
.private/
.logs/
.task/
.temp*
.todo*
TODO.md
report/

# -------------------------------------------------------
# Tasks
# -------------------------------------------------------
bootstrap/.latest-template.sha

# -------------------------------------------------------
# Retain (must be last — negations override above)
# -------------------------------------------------------
!.gitkeep
!.gitignore
!.env.example
!.env.sample
!**.gitkeep
!**.gitignore
!*.sops.*
